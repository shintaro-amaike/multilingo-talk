# ===== Frontend Environment Variables =====

# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api

# Feature Flags
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_PWA=true
VITE_ENABLE_ANALYTICS=true

# External Services
VITE_SENTRY_DSN=
VITE_GOOGLE_ANALYTICS_ID=

# ===== Backend Environment Variables =====

# FastAPI
FASTAPI_ENV=development
DEBUG=true

# Database
DATABASE_URL=sqlite:///./multilingo.db
# For PostgreSQL: postgresql://user:password@localhost/multilingo

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# External APIs
OPENAI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_CREDENTIALS=

# Email Configuration
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Monitoring & Logging
SENTRY_DSN=
LOG_LEVEL=INFO

# Redis (Optional)
REDIS_URL=redis://localhost:6379/0

# ===== Docker Compose =====

# Compose
COMPOSE_PROJECT_NAME=multilingo-talk
COMPOSE_FILE=docker-compose.yml

# Backend Container
BACKEND_PORT=8000
BACKEND_RELOAD=true

# Frontend Container
FRONTEND_PORT=5173

# PostgreSQL (if used)
POSTGRES_USER=multilingo
POSTGRES_PASSWORD=your-password-change-in-production
POSTGRES_DB=multilingo
